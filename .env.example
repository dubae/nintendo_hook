# Nintendo Switch 2 product page.
PRODUCT_URL=https://store.nintendo.co.kr/beeskb6aakor

# Be polite to the official store. 60 seconds is a reasonable default.
CHECK_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=20
STATE_FILE=.monitor-state.json
ALERT_ON_START=true
ALERT_REPEAT_MINUTES=0
ERROR_ALERT_THRESHOLD=3

# Discord is the easiest notification method.
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL
DISCORD_WEBHOOK_URL=

# Optional generic JSON webhook.
WEBHOOK_URL=
WEBHOOK_BEARER_TOKEN=

# Optional SMTP email. Gmail requires an app password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
